<Page x:Class="VictumPOS.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource AppBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24" MaxWidth="1120">
            <StackPanel>
                <Border Style="{StaticResource PageHeaderCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Configuracion de Impresoras"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Configura cocina, caja y bar con ESC/POS de red o impresoras Windows."
                                   Foreground="#D9FFFFFF"
                                   FontSize="14"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,9,0">
                        <StackPanel>
                            <TextBlock Text="Cocina" Style="{StaticResource CardTitleText}"/>
                            <TextBlock Text="Tickets de preparacion" Style="{StaticResource SubtitleText}" Margin="0,2,0,10"/>
                            <TextBlock Text="Tipo de conexion" Style="{StaticResource FieldLabelText}"/>
                            <ComboBox x:Name="KitchenType">
                                <ComboBoxItem Content="ESC/POS (Red)" Tag="network"/>
                                <ComboBoxItem Content="Impresora Windows" Tag="windows"/>
                            </ComboBox>

                            <StackPanel x:Name="KitchenNetworkPanel">
                                <TextBlock Text="IP de la impresora" Style="{StaticResource FieldLabelText}"/>
                                <TextBox x:Name="KitchenIP"/>
                                <TextBlock Text="Puerto" Style="{StaticResource FieldLabelText}"/>
                                <TextBox x:Name="KitchenPort"/>
                            </StackPanel>

                            <StackPanel x:Name="KitchenWindowsPanel">
                                <TextBlock Text="Impresora Windows" Style="{StaticResource FieldLabelText}"/>
                                <ComboBox x:Name="KitchenWindowsPrinter"/>
                            </StackPanel>

                            <Button Click="TestKitchen_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,14,0,0">
                                <TextBlock Text="Probar cocina" Foreground="White"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="9,0">
                        <StackPanel>
                            <TextBlock Text="Caja" Style="{StaticResource CardTitleText}"/>
                            <TextBlock Text="Facturas y recibos" Style="{StaticResource SubtitleText}" Margin="0,2,0,10"/>
                            <TextBlock Text="Tipo de conexion" Style="{StaticResource FieldLabelText}"/>
                            <ComboBox x:Name="CashType">
                                <ComboBoxItem Content="ESC/POS (Red)" Tag="network"/>
                                <ComboBoxItem Content="Impresora Windows" Tag="windows"/>
                            </ComboBox>

                            <StackPanel x:Name="CashNetworkPanel">
                                <TextBlock Text="IP de la impresora" Style="{StaticResource FieldLabelText}"/>
                                <TextBox x:Name="CashIP"/>
                                <TextBlock Text="Puerto" Style="{StaticResource FieldLabelText}"/>
                                <TextBox x:Name="CashPort"/>
                            </StackPanel>

                            <StackPanel x:Name="CashWindowsPanel">
                                <TextBlock Text="Impresora Windows" Style="{StaticResource FieldLabelText}"/>
                                <ComboBox x:Name="CashWindowsPrinter"/>
                            </StackPanel>

                            <Button Click="TestCash_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,14,0,0">
                                <TextBlock Text="Probar caja" Foreground="White"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="9,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Bar" Style="{StaticResource CardTitleText}"/>
                            <TextBlock Text="Tickets de bebidas" Style="{StaticResource SubtitleText}" Margin="0,2,0,10"/>
                            <TextBlock Text="Tipo de conexion" Style="{StaticResource FieldLabelText}"/>
                            <ComboBox x:Name="BarType">
                                <ComboBoxItem Content="ESC/POS (Red)" Tag="network"/>
                                <ComboBoxItem Content="Impresora Windows" Tag="windows"/>
                            </ComboBox>

                            <StackPanel x:Name="BarNetworkPanel">
                                <TextBlock Text="IP de la impresora" Style="{StaticResource FieldLabelText}"/>
                                <TextBox x:Name="BarIP"/>
                                <TextBlock Text="Puerto" Style="{StaticResource FieldLabelText}"/>
                                <TextBox x:Name="BarPort"/>
                            </StackPanel>

                            <StackPanel x:Name="BarWindowsPanel">
                                <TextBlock Text="Impresora Windows" Style="{StaticResource FieldLabelText}"/>
                                <ComboBox x:Name="BarWindowsPrinter"/>
                            </StackPanel>

                            <Button Click="TestBar_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,14,0,0">
                                <TextBlock Text="Probar bar" Foreground="White"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource ActionBarStyle}">
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="Los cambios se guardan en ProgramData y se conservan al actualizar."
                                   Foreground="{StaticResource AppMutedTextBrush}"
                                   VerticalAlignment="Center"
                                   DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Click="ReloadPrinters_Click">
                                <TextBlock Text="Recargar impresoras" Foreground="White"/>
                            </Button>
                            <Button Click="Save_Click" Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock Text="Guardar configuracion" Foreground="White"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border x:Name="StatusBar"
                        Padding="12,10"
                        Background="#F0FDFA"
                        BorderBrush="#00ACC1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed">
                    <TextBlock x:Name="StatusText" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
